@page "/"
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@using System.Text
@inject NavigationManager NavigationManager
@inject IJSRuntime JsRuntime
@inject FileStorageService FileStorage
@inject UserSessionService UserSession
@inject AuthenticationService Authentication
@using NovaCryptG.Services

<PageTitle>NovaCrypt - Encryption Tool</PageTitle>

<div class="container py-4">
    <div class="text-center mb-5">
        <h1 class="display-5 fw-bold">
            Encryption Tool
        </h1>
        <hr class="my-4 w-50 mx-auto">
    </div>

    <div class="row g-4">
        <!-- Text Editor Display -->
        <div class="col-12">
            <div class="card shadow-sm">
                <div class="card-header bg-transparent">
                    Text Editor
                </div>
                <div class="card-body">
                    <textarea @bind="_textContent"
                              @oninput="OnTextChanged"
                              rows="12"
                              class="form-control"
                              style="resize: none;"
                              placeholder="Enter or paste text here ..."></textarea>
                    @if (_isModified)
                    {
                        <div class="mt-2 text-warning small">
                            Unsaved changes
                        </div>
                    }
                </div>
            </div>
        </div>

        <!-- Encryption Password and Button Display -->
        <div class="col-md-6">
            <div class="card shadow-sm h-100">
                <div class="card-header bg-transparent">
                    Encryption Password
                </div>
                <div class="card-body">
                    <div class="mb-3">
                        <label class="form-label fw-semibold">
                            Password
                        </label>
                        <input type="password" @bind="_encryptPassword" @bind:event="oninput" class="form-control" placeholder="Enter password" />
                        @if (!string.IsNullOrEmpty(_encryptPassword) && (_encryptPassword.Length < 8))
                        {
                            <div class="text-danger small mt-1">
                                Password must be at least 8 characters long
                            </div>
                        }
                        else if (!string.IsNullOrEmpty(_encryptPassword) && !_encryptPassword.Any(char.IsUpper))
                        {
                            <div class="text-danger small mt-1">
                                Password requires at least 1 upper case character
                            </div>
                        }
                        else if (!string.IsNullOrEmpty(_encryptPassword) && !_encryptPassword.Any(char.IsDigit))
                        {
                            <div class="text-danger small mt-1">
                                Password requires at least 1 digit
                            </div>
                        }
                        else if (!string.IsNullOrEmpty(_encryptPassword) && !_encryptPassword.Any(c => !char.IsLetterOrDigit(c)))
                        {
                            <div class="text-danger small mt-1">
                                Password requires at least 1 special character
                            </div>
                        }
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">
                            Confirm Password
                        </label>
                        <input type="password" @bind="_confirmEncryptPassword" @bind:event="oninput" class="form-control" placeholder="Confirm password" />
                        @if (!string.IsNullOrEmpty(_confirmEncryptPassword) && (_encryptPassword != _confirmEncryptPassword))
                        {
                            <div class="text-danger small mt-1">
                                Passwords do not match
                            </div>
                        }
                    </div>
                </div>
                <div class="card-footer bg-transparent">
                    <button class="btn btn-primary w-100" @onclick="EncryptAsync" disabled="@((_encryptPassword != _confirmEncryptPassword) || string.IsNullOrEmpty(_encryptPassword) || (_encryptPassword.Length < 8) || !_encryptPassword.Any(char.IsUpper) || !_encryptPassword.Any(char.IsDigit) || !_encryptPassword.Any(c => !char.IsLetterOrDigit(c)) || string.IsNullOrWhiteSpace(_textContent))">
                        Encrypt
                    </button>
                </div>
            </div>
        </div>

        <!-- Decryption Password and Button Display -->
        <div class="col-md-6">
            <div class="card shadow-sm h-100">
                <div class="card-header bg-transparent">
                    Decryption Password
                </div>
                <div class="card-body">
                    <div class="mb-3">
                        <label class="form-label fw-semibold">
                            Password
                        </label>
                        <input type="password" @bind="_decryptPassword" @bind:event="oninput" class="form-control" placeholder="Enter password" />
                        <!-- I have deliberately removed the password validation checks as they are unnecessary for the decryption password -->
                    </div>
                </div>
                <div class="card-footer bg-transparent">
                    <button class="btn btn-secondary w-100" @onclick="DecryptAsync" disabled="@(string.IsNullOrEmpty(_decryptPassword) || string.IsNullOrWhiteSpace(_textContent))">
                        Decrypt
                    </button>
                </div>
            </div>
        </div>

        <!-- Saved Files and Save, New, Load, and Delete buttons display. -->
        <div class="col-12">
            <div class="card shadow-sm">
                <div class="card-header bg-transparent">
                    Files
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-8 mb-3 mb-md-0">
                            <select @bind="_selectedFile" class="form-control" size="8" style="min-height: 200px;">
                                @if (_fileList.Any())
                                {
                                    @foreach (var file in _fileList)
                                    {
                                        <option value="@file">@file</option>
                                    }
                                }
                                else
                                {
                                    <option disabled>No files saved yet</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-4 d-flex flex-column">
                            <div class="d-grid gap-2 flex-grow-1">
                                <button class="btn btn-success w-100" @onclick="SaveFile" disabled="@(string.IsNullOrWhiteSpace(_textContent))">
                                    Save File
                                </button>
                                <button class="btn btn-info w-100" @onclick="NewFile">
                                    New File
                                </button>
                                <button class="btn btn-warning w-100" @onclick="LoadFile" disabled="@(string.IsNullOrEmpty(_selectedFile))">
                                    Load Selected
                                </button>
                                <button class="btn btn-danger w-100" @onclick="DeleteFile" disabled="@(string.IsNullOrEmpty(_selectedFile))">
                                    Delete Selected
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- This button is not present in the designs and should not technically exist. However, I needed a better way to add users. -->
<!-- Admin Panel button (displays for admin users only) -->
@if (_isAdmin == true)
{
    <div class="container py-4">
            <button class="btn btn-primary w-100" @onclick="GoToAdminPanel">Admin Panel</button>
    </div>
}

<!-- Universal Modal -->
<div class="modal fade @(_showModal ? "show d-block" : "")" tabindex="-1" style="@(_showModal ? "display:block;" : "display:none;")" aria-hidden="@(!_showModal)">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">@_modalTitle</h5>
                <button type="button" class="btn-close" @onclick="CloseModal"></button>
            </div>
            <div class="modal-body">
                @_modalMessage
            </div>
            <div class="modal-footer">
                @if (!_isInfoOnly)
                {
                    <button type="button" class="btn btn-secondary" @onclick="CloseModal">Cancel</button>
                }
                <button type="button" class="btn btn-primary" @onclick="ConfirmModalAction">@_modalConfirmText</button>
            </div>
        </div>
    </div>
</div>
@if (_showModal)
{
    <div class="modal-backdrop fade show"></div>
}

@code {
    private List<string?> _fileList = new();
    private string _selectedFile = "";
    private bool _isModified;
    private bool _isEncrypted; // True if current text is base64 (Potentially encrypted)
    private bool? _isAdmin = false; // Admin check

    // Text and password input
    private string _textContent = "";
    private string _encryptPassword = "";
    private string _confirmEncryptPassword = "";
    private string _decryptPassword = "";

    // Modal state
    private bool _showModal;
    private string _modalTitle = "";
    private string _modalMessage = "";
    private string _modalConfirmText = "OK";
    private bool _isInfoOnly = true;
    private Func<Task>? _onConfirm;

    protected override async Task OnInitializedAsync()
    {
        // User logged in check
        if (!UserSession.IsLoggedIn)
        {
            NavigationManager.NavigateTo("/Login");
            return;
        }

        // User admin privilege check
        _isAdmin = await Authentication.IsUserAdminAsync(UserSession.CurrentUserName!);

        RefreshFileList();
    }

    // This function is not present in the designs and should not technically exist. However, I needed a better way to add users.
    private void GoToAdminPanel() => NavigationManager.NavigateTo("/AdminPanel");

    private void RefreshFileList()
    {
        var result = FileStorage.GetFileList();
        if (result.Success)
        {
            _fileList = result.FileList;
        }
        else
        {
            _fileList.Clear();
            ShowMessage("Error", result.Message);
        }
        StateHasChanged();
    }

    private void OnTextChanged()
    {
        _isModified = true;
        _isEncrypted = false;
        StateHasChanged();
    }

    // Function to check whether text is base64
    private static bool IsBase64String(string s)
    {
        if (string.IsNullOrEmpty(s)) return false;
        s = s.Trim(); // string
        if (s.Length % 4 != 0) return false;
        try
        {
            Convert.FromBase64String(s);
            return true;
        }
        catch
        {
            return false;
        }
    }

    // Modal helpers
    // I have decided not to use async/await, due to the modal not closing instantly after a button has been pressed
    private void OpenModal(string title, string message, string confirmText, Func<Task> confirmAction, bool infoOnly = false)
    {
        _modalTitle = title;
        _modalMessage = message;
        _modalConfirmText = confirmText;
        _isInfoOnly = infoOnly;
        _onConfirm = confirmAction;
        _showModal = true;
        StateHasChanged();
    }

    private void ShowMessage(string title, string message) =>
        OpenModal(title, message, "OK", () => Task.CompletedTask, infoOnly: true);

    private void CloseModal()
    {
        _showModal = false;
        _onConfirm = null;
        StateHasChanged();
    }

    private void ConfirmModalAction()
    {
        if (_onConfirm != null)
            _onConfirm();
        CloseModal();
    }

// Procedure to encrypt the plain text input
    private async Task EncryptAsync()
    {
        /*
         This could be used to check whether the text is already encrypted.
         However, this is unnecessary as the user may want to encrypt base64 text or
         run the encryption several times.
        if (IsBase64String(_textContent))
        {
            ShowMessage("Encryption Failed", "The current text is base64, cannot be encrypted.");
            return;
        }
        */

        byte[] plainBytes = Encoding.UTF8.GetBytes(_textContent);
        var result = await EncryptionService.EncryptFileAsync(plainBytes, "temp", _encryptPassword);
        if (result.Success)
        {
            _textContent = Convert.ToBase64String(result.Data);
            _isEncrypted = true;
            ShowMessage("Encryption", "Encryption successful.");
            StateHasChanged();
        }
        else
        {
            ShowMessage("Encryption Failed", result.Message);
        }
    }

    // Procedure to decrypt the encrypted text
    private async Task DecryptAsync()
    {
        // Check if text is base64
        if (!IsBase64String(_textContent))
        {
            ShowMessage("Decryption Failed", "The current text is not base64, cannot be decrypted.");
            return;
        }

        byte[] encryptedBytes = Convert.FromBase64String(_textContent);
        var result = await EncryptionService.DecryptFileAsync(encryptedBytes, "temp.encrypted", _decryptPassword);
        if (result.Success)
        {
            _textContent = Encoding.UTF8.GetString(result.Data);
            _isEncrypted = false;
            ShowMessage("Decryption", "Decryption attempted.");
            StateHasChanged();
        }
        else
        {
            ShowMessage("Decryption Failed", result.Message);
        }
    }

    // Save File
    private void SaveFile()
    {
        if (_isEncrypted)
        {
            _ = PerformSaveFileAsync();
        }
        else
        {
            ShowMessage("Save Failed", "The current text is not encrypted or validated as encrypted.");
        }
    }

    private async Task PerformSaveFileAsync()
    {
        // Prompt for filename
        string fileName = await JsRuntime.InvokeAsync<string>("prompt", "Enter a name for the encrypted file (without extension):");
        if (string.IsNullOrWhiteSpace(fileName))
        {
            ShowMessage("Save Cancelled", "The save was cancelled.");
            return;
        }

        // Sanitise: replace spaces with underscores
        fileName = fileName.Replace(" ", "_");
        string fullFileName = $"{fileName}.encrypted";

        var result = await FileStorage.SaveFileAsync(fullFileName, _textContent);
        if (result.Success)
        {
            ShowMessage($"File {fullFileName}", result.Message);
            _isModified = false;
            RefreshFileList();
        }
        else
        {
            ShowMessage("Error", result.Message);
        }
    }

    // New file/Clear text
    private void NewFile()
    {
        if (_isModified && !string.IsNullOrWhiteSpace(_textContent))
        {
            OpenModal(
                "New File?",
                "You have unsaved changes. Are you sure you want to proceed?",
                "Proceed",
                () =>
                {
                    PerformNewFile();
                    return Task.CompletedTask;
                }
            );
        }
        else
        {
            PerformNewFile();
        }
    }

    private void PerformNewFile()
    {
        _textContent = "";
        _isModified = false;
        _isEncrypted = false;
        StateHasChanged();
    }

    // Load File
    private void LoadFile()
    {
        if (_isModified && !string.IsNullOrWhiteSpace(_textContent))
        {
            OpenModal(
                "Load File?",
                "You have unsaved changes. Are you sure you want to proceed?",
                "Proceed",
                () =>
                {
                    _ = PerformLoadFileAsync();
                    return Task.CompletedTask;
                }
            );
        }
        else
        {
            _ = PerformLoadFileAsync();
        }
    }

    private async Task PerformLoadFileAsync()
    {
        var result = await FileStorage.LoadFileAsync(_selectedFile);
        if (result.Success)
        {
            _textContent = result.Content;
            _isEncrypted = IsBase64String(result.Content);
            _isModified = false;
            ShowMessage("Loaded", $"Loaded {_selectedFile}");
        }
        else
        {
            ShowMessage("Loading Failed", result.Message);
        }
        StateHasChanged();
    }

    // Delete File
    private void DeleteFile()
    {
        OpenModal(
            "Delete File?",
            $"Are you sure you want to delete {_selectedFile}? This action cannot be undone.",
            "Delete",
            () =>
            {
                PerformDeleteFile();
                return Task.CompletedTask;
            }
        );
    }

    private void PerformDeleteFile()
    {
        var fileToDelete = _selectedFile;

        // Check if a file is selected and exists
        if (string.IsNullOrEmpty(fileToDelete)) return;

        var result = FileStorage.DeleteFile(fileToDelete);
        if (result.Success)
        {
            ShowMessage("Deleted", result.Message);
            RefreshFileList();

            // Clear selected file if it was the one just deleted
            if (_selectedFile == fileToDelete)
            {
                _selectedFile = "";
            }
        }
        else
        {
            ShowMessage("Error", result.Message);
        }
    }
}